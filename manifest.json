{
  "manifest_version": 3,
  "name": "YouTube Focus",
  "description": "A Chrome extension that helps you stay focused on YouTube by blocking distractions and tracking your watch time.",
  "version": "1.0",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
